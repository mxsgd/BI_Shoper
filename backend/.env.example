DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/bi_shoper

# --- Testy bazy / Shoper WebAPI (skopiuj do backend/.env; ten plik BEZ prawdziwych haseł) ---
# Konto Shoper z dostępem WebAPI — używane wyłącznie do POST /auth przy odświeżaniu tokena:
SHOPER_MK_LOGIN=
SHOPER_MK_PASSWORD=
SHOPER_MK_API_URL=https://www.sklep-mkfoam.pl/webapi/rest

# Opcjonalnie: pomiń /auth i użyj gotowego tokena:
# SHOPER_MK_ACCESS_TOKEN=

# Który rekord stores.api_token zaktualizować:
# SHOPER_MK_STORE_ID=1
